PORT=4000
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/assets-manager
JWT_SECRET=cambia_esto_por_un_secreto_seguro
FRONTEND_URL=https://tu-app.vercel.app
GMAIL_VAULT_KEY=genera_uno_con_node_-e_"console.log(require('crypto').randomBytes(32).toString('hex'))"

# Aviso a un grupo de Telegram cuando llega una Solicitud (de Cuentas o de
# Ingreso) — opcional: si se dejan vacías, simplemente no se manda nada.
# Ver backend/src/utils/telegram.js.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Notificaciones push al empleado (Mesa de Ayuda) cuando Sistemas responde un
# ticket — opcional: si se dejan vacías, simplemente no se manda nada. Generar
# el par UNA sola vez con: node -e "console.log(require('web-push').generateVAPIDKeys())"
# La pública también debe copiarse a VITE_VAPID_PUBLIC_KEY en el frontend.
# Ver backend/src/utils/webPush.js.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:tu-correo@selectshop.com.mx
