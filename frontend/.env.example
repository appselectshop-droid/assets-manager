# URL del backend en Render (sin barra al final)
# En local no hace falta: el proxy de Vite ya redirige /api → localhost:4000
VITE_API_URL=https://tu-backend.onrender.com

# Misma llave pública VAPID que VAPID_PUBLIC_KEY en el backend (ver
# backend/.env.example) — es pública a propósito, segura de exponer en el
# bundle. Sin esto, el botón "Activar notificaciones" de Mesa de Ayuda no
# funciona.
VITE_VAPID_PUBLIC_KEY=
